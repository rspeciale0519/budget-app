// Ledger — Prisma schema.
// Money columns use @db.Decimal(14,2); dates use @db.Date (calendar dates).
// Models are added across Tasks 7–9.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Identity & access (Task 7). userId values are Supabase auth.users ids
// (uuid); we store the uuid without a cross-schema FK to auth.users.
// ─────────────────────────────────────────────────────────────────────────

enum OrgRole {
  owner
  admin
  member
}

enum WorkspaceRole {
  admin
  viewer
}

enum WorkspaceType {
  personal
  business
}

model Organization {
  id         String          @id @default(cuid())
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  memberships OrgMembership[]
  workspaces Workspace[]
}

model OrgMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       @db.Uuid
  role           OrgRole
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Workspace {
  id             String                @id @default(cuid())
  organizationId String
  name           String
  type           WorkspaceType
  color          String
  icon           String?
  sortOrder      Int                   @default(0)
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    WorkspaceMembership[]

  @@index([organizationId])
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String        @db.Uuid
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────
// Money sources & ledger (Task 8). workspaceId is a scalar tenant key (used
// by RLS), not a relation. Money is Decimal(14,2); dates are @db.Date.
// billId / transferPairId are scalar links (service-layer integrity, spec §9).
// ─────────────────────────────────────────────────────────────────────────

enum AccountType {
  checking
  savings
  credit_card
  loan
  cash
}

enum TxSource {
  csv
  manual
}

enum CategoryKind {
  income
  expense
}

model Account {
  id             String        @id @default(cuid())
  workspaceId    String
  name           String
  type           AccountType
  institution    String
  last4          String?
  openingBalance Decimal       @db.Decimal(14, 2)
  openingDate    DateTime      @db.Date
  currency       String        @default("USD")
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
  importBatches  ImportBatch[]

  @@index([workspaceId])
}

model Category {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  kind         CategoryKind
  parentId     String?
  createdAt    DateTime      @default(now())
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]    @relation("CategoryHierarchy")
  transactions Transaction[]

  @@index([workspaceId])
}

model ImportBatch {
  id           String        @id @default(cuid())
  workspaceId  String
  accountId    String
  filename     String
  rowCount     Int
  status       String        @default("committed")
  importedAt   DateTime      @default(now())
  archivedAt   DateTime?
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([workspaceId])
}

model Transaction {
  id             String       @id @default(cuid())
  workspaceId    String
  accountId      String
  date           DateTime     @db.Date
  amount         Decimal      @db.Decimal(14, 2)
  description    String
  merchant       String?
  categoryId     String?
  notes          String?
  source         TxSource
  importBatchId  String?
  dedupeHash     String
  isTransfer     Boolean      @default(false)
  transferPairId String?
  billId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category       Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([workspaceId, date])
  @@index([workspaceId, accountId, dedupeHash])
}
