# Copy to .env.local and fill from `supabase start` output (local dev) or your host.
# Local-only demo credentials are safe to share; never commit real secrets.

# Supabase API (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connections
# DATABASE_URL: runtime connection. Authenticates as the unprivileged,
#   RLS-subject `app_runtime` role.
# ADMIN_DATABASE_URL: runtime privileged client (prismaAdmin). Authenticates as
#   the `app_admin` role — cross-tenant DML via blanket admin policies, but NOT a
#   superuser: no DDL, no other schemas (incl. auth). Prod password is set out of
#   band (ALTER ROLE) and stored only in the host env, never committed.
# DIRECT_URL: privileged connection (postgres) used ONLY for prisma migrate + seed
#   (kept out of the app's validated runtime env; not read by the running app).
DATABASE_URL=
ADMIN_DATABASE_URL=
DIRECT_URL=

# Google OAuth (localhost callback is allowed in dev)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
