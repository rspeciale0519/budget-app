# Copy to .env.local and fill from `supabase start` output (local dev) or your host.
# Local-only demo credentials are safe to share; never commit real secrets.

# Supabase API (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connections
# DATABASE_URL: runtime connection. From Task 10 onward this authenticates as the
#   unprivileged, RLS-subject `app_runtime` role.
# DIRECT_URL: privileged connection (postgres) used ONLY for prisma migrate + seed.
DATABASE_URL=
DIRECT_URL=

# Google OAuth (localhost callback is allowed in dev)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
